# API
API_PORT=8080
API_AUTO_MIGRATE_ON_START=false

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ota
POSTGRES_PASSWORD=ota
POSTGRES_DB=ota

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Worker
WORKER_TASK_STATS_RETENTION_HOURS=168

# S3 protocol compatible object storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=ota-packages
S3_ACCESS_KEY_ID=<your-s3-access-key-id>
S3_SECRET_ACCESS_KEY=<your-s3-secret-access-key>
S3_PUBLIC_BASE_URL=http://localhost:9000/ota-packages
S3_SIGNED_URL_TTL_SEC=600

# Security keys
JWT_SECRET=<your-jwt-secret>
DEVICE_SIGNING_SECRET=<your-device-signing-secret>
OIDC_STATE_SIGNING_KEY=<your-oidc-state-signing-key>

# Local auth (disabled by default; use OIDC in production)
LOCAL_AUTH_ENABLED=false
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD_HASH=<bcrypt-hash>

# OIDC (OAuth2.0 identity layer)
OIDC_ENABLED=true
OIDC_ISSUER_URL=http://keycloak:8080/realms/ota-dev
OIDC_AUTHORIZE_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_CLIENT_ID=ota-console
OIDC_CLIENT_SECRET=<your-oidc-client-secret>
OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/sso/callback
OIDC_SCOPES=openid profile email
OIDC_STATE_SIGNING_KEY=<your-oidc-state-signing-key>
OIDC_STATE_TTL_SEC=300
OIDC_MOCK_ENABLED=true
OIDC_MOCK_USER=oidc-user

# Keycloak dev bootstrap
KEYCLOAK_ADMIN=<dev-keycloak-admin>
KEYCLOAK_ADMIN_PASSWORD=<dev-keycloak-admin-password>

# MinIO dev bootstrap
MINIO_ROOT_USER=<dev-minio-root-user>
MINIO_ROOT_PASSWORD=<dev-minio-root-password>
