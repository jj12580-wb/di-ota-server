# ==========================================
# API & 数据库初始化
# ==========================================
API_PORT=8080
API_AUTO_MIGRATE_ON_START=true
GOPROXY=https://goproxy.cn,direct

# ==========================================
# 核心组件连接 (使用容器名)
# ==========================================
POSTGRES_HOST=ota-postgres
POSTGRES_PORT=5432
POSTGRES_USER=ota
POSTGRES_PASSWORD=ota
POSTGRES_DB=ota

REDIS_ADDR=ota-redis:6379
RABBITMQ_URL=amqp://guest:guest@ota-rabbitmq:5672/

# ==========================================
# 对象存储 (MinIO)
# ==========================================
S3_ENDPOINT=http://ota-minio:9000
S3_REGION=us-east-1
S3_BUCKET=ota-packages
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=https://iot.map360.cn/ota-packages
S3_SIGNED_URL_TTL_SEC=600

# ==========================================
# 安全密钥 (必须设置且保持一致)
# ==========================================
AUTH_JWT_SECRET=ota_server_secure_secret_2026
JWT_SECRET=ota_server_secure_secret_2026
DEVICE_SIGNING_SECRET=device_secure_key_2026
AUTH_OIDC_STATE_SIGNING_KEY=state_secure_key_2026

# ==========================================
# 本地认证配置 (解决 401 的核心)
# ==========================================
AUTH_LOCAL_AUTH_ENABLED=true
AUTH_LOCAL_ADMIN_USERNAME=admin
# 🚩 注意：不要给这个 Hash 值加任何引号，确保 $ 符号原样保留

AUTH_LOCAL_ADMIN_PASS_HASH=$$2a$$10$$ByI76zSscSByX6mP7mS8vO.p1y5szY6y7v1V4M.K5
# 兼容性冗余配置
LOCAL_AUTH_ENABLED=true
LOCAL_ADMIN_USERNAME=admin

LOCAL_ADMIN_PASSWORD_HASH=$$2a$$10$$ByI76zSscSByX6mP7mS8vO.p1y5szY6y7v1V4M.K5

# ==========================================
# OIDC & Mock
# ==========================================
AUTH_OIDC_ENABLED=false
OIDC_ENABLED=false
OIDC_MOCK_ENABLED=true
OIDC_MOCK_USER=oidc-user

# ==========================================
# 外部设备系统（AMS）代理配置
# ==========================================
# 外部接口域名前缀（不含尾随 / 也可以，服务端会自动处理）
# 示例：https://ams.map360.cn
AMS_BASE_URL=https://ams.map360.cn
# AMS 请求超时（秒）
AMS_TIMEOUT_SEC=8
# AMS 登录账号（用于获取 token）
AMS_USERNAME=admin
AMS_PASSWORD=admin123

# ==========================================
# 初始化账号 (Keycloak/MinIO)
# ==========================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin